  const sx2 = rnd(-80, 80);
  const rot = rnd(120, 360);
  const dur = rnd(1.4, 2.2);
  el.style.cssText = `left:${x}px;top:${y}px;--sx:${sx}px;--sx2:${sx2}px;--rot:${rot}deg;--fdur:${dur}s;`;
  el.innerHTML = svg;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), dur * 1000 + 100);
}
 
/* ---- WEB AUDIO ENGINE ---- */
let audioCtx = null;
function getAudioCtx() {
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  return audioCtx;
}
 
function playSound(type) {
  try {
    const ctx = getAudioCtx();
    const master = ctx.createGain();
    master.gain.setValueAtTime(0.18, ctx.currentTime);
    master.connect(ctx.destination);
 
    const sounds = {
      // Classic 8-bit beep
      beep: () => {
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(master);
        o.type = 'square';
        const freqs = [523, 659, 784, 1047, 880, 698];
        o.frequency.setValueAtTime(freqs[rndInt(0,freqs.length)], ctx.currentTime);
        g.gain.setValueAtTime(1, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.15);
        o.start(); o.stop(ctx.currentTime + 0.15);
      },
      // Pixel pop — short blip
      pop: () => {
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(master);
        o.type = 'sine';
        o.frequency.setValueAtTime(800, ctx.currentTime);
        o.frequency.exponentialRampToValueAtTime(200, ctx.currentTime + 0.08);
        g.gain.setValueAtTime(1, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.08);
        o.start(); o.stop(ctx.currentTime + 0.1);
      },
      // Coin collect — rising arpeggio
      coin: () => {
        [523, 659, 784, 1047].forEach((f, i) => {
          const o = ctx.createOscillator();
          const g = ctx.createGain();
          o.connect(g); g.connect(master);
          o.type = 'triangle';
          o.frequency.setValueAtTime(f, ctx.currentTime + i * 0.05);
          g.gain.setValueAtTime(0.8, ctx.currentTime + i * 0.05);
          g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + i * 0.05 + 0.1);
          o.start(ctx.currentTime + i * 0.05);
          o.stop(ctx.currentTime + i * 0.05 + 0.12);
        });
      },
      // Laser zap
      laser: () => {
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(master);
        o.type = 'sawtooth';
        o.frequency.setValueAtTime(1200, ctx.currentTime);
        o.frequency.exponentialRampToValueAtTime(80, ctx.currentTime + 0.2);
        g.gain.setValueAtTime(1, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
        o.start(); o.stop(ctx.currentTime + 0.22);
      },
      // Explosion thud
      boom: () => {
        const buf = ctx.createBuffer(1, ctx.sampleRate * 0.3, ctx.sampleRate);
        const data = buf.getChannelData(0);
        for (let i = 0; i < data.length; i++) data[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / data.length, 2);
        const src = ctx.createBufferSource();
        const g = ctx.createGain();
        const filter = ctx.createBiquadFilter();
        filter.type = 'lowpass'; filter.frequency.value = 200;
        src.buffer = buf;
        src.connect(filter); filter.connect(g); g.connect(master);
        g.gain.setValueAtTime(2, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
        src.start(); src.stop(ctx.currentTime + 0.32);
      },
      // Synthwave chord
      synth: () => {
        const chords = [[262,330,392],[294,370,440],[330,415,494],[349,440,523]];
        const chord = chords[rndInt(0,chords.length)];
        chord.forEach(f => {
          const o = ctx.createOscillator();
          const g = ctx.createGain();
          o.connect(g); g.connect(master);
          o.type = 'sawtooth';
          o.frequency.setValueAtTime(f, ctx.currentTime);
          g.gain.setValueAtTime(0.3, ctx.currentTime);
          g.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.25);
          o.start(); o.stop(ctx.currentTime + 0.28);
        });
      },
      // Power-up sweep
      powerup: () => {
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(master);
        o.type = 'square';
        o.frequency.setValueAtTime(200, ctx.currentTime);
        o.frequency.exponentialRampToValueAtTime(1600, ctx.currentTime + 0.3);
        g.gain.setValueAtTime(0.8, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.35);
        o.start(); o.stop(ctx.currentTime + 0.38);
      },
    };
 
    const keys = Object.keys(sounds);
    const pick = type || keys[rndInt(0, keys.length)];
    sounds[pick]?.();
  } catch(e) {}
}
 
// Hover sound — subtle tick
function playHoverTick() {
  try {
    const ctx = getAudioCtx();
    const o = ctx.createOscillator();
    const g = ctx.createGain();
    o.connect(g); g.connect(ctx.destination);
    o.type = 'square';
    o.frequency.setValueAtTime(440, ctx.currentTime);
    g.gain.setValueAtTime(0.04, ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.04);
    o.start(); o.stop(ctx.currentTime + 0.05);
  } catch(e) {}
}
 
/* ---- MAIN CLICK HANDLER ---- */
document.addEventListener('click', e => {
  const x = e.clientX, y = e.clientY;
  playSound(); // random sound every click
  addCombo();
  pixelExplosion(x, y);
  rippleWave(x, y);
  const sprCount = rndInt(2, 5);
  for (let i = 0; i < sprCount; i++) {
    setTimeout(() => spawnSprite(x + rnd(-20,20), y + rnd(-20,20)), i * 60);
  }
  const word = WORDS[rndInt(0, WORDS.length)];
  showLabel(x + rnd(-30, 30), y - 20, word, 9, rndColor());
});
 
/* ---- BUTTON SPECIAL EFFECTS ---- */
document.querySelectorAll('.btn, .skill-card, .project-card, .contact-item').forEach(el => {
  el.addEventListener('click', function(e) {
    playSound('coin');
    for (let i = 0; i < 6; i++) {
      setTimeout(() => {
        const r = this.getBoundingClientRect();
        pixelExplosion(r.left + rnd(0, r.width), r.top + rnd(0, r.height));
      }, i * 80);
    }
  });
  el.addEventListener('mouseenter', function() {
    playHoverTick();
    this.style.transition = 'all 0.1s';
  });
});
 
/* ---- KONAMI CODE ---- */
const KONAMI = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
let konamiIdx = 0;
document.addEventListener('keydown', e => {
  if (e.key === KONAMI[konamiIdx]) {
    playHoverTick();
    konamiIdx++;
    if (konamiIdx === KONAMI.length) {
      playSound('powerup');
      setTimeout(() => playSound('coin'), 400);
      document.getElementById('easter-egg').classList.add('show');
      for (let i = 0; i < 30; i++) {
        setTimeout(() => {
          pixelExplosion(rnd(0, window.innerWidth), rnd(0, window.innerHeight));
          spawnSprite(rnd(100, window.innerWidth-100), rnd(100, window.innerHeight-100));
        }, i * 80);
      }
      konamiIdx = 0;
    }
  } else { konamiIdx = 0; }
});
 
/* ---- SCROLL REVEAL ---- */
const obs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) e.target.classList.add('visible');
  });
}, { threshold: 0.1 });
document.querySelectorAll('.observe').forEach(el => obs.observe(el));
 
/* ---- SKILL BAR ---- */
const skillObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.querySelectorAll('.skill-fill').forEach((bar, i) => {
        const w = bar.style.width;
        bar.style.width = '0';
        setTimeout(() => {
          bar.style.width = w;
          playSound('beep');
        }, 200 + i * 120);
      });
    }
  });
}, { threshold: 0.3 });
const skillsGrid = document.querySelector('.skills-grid');
if (skillsGrid) skillObs.observe(skillsGrid);
 
/* ---- IDLE AMBIENT PARTICLES ---- */
setInterval(() => {
  if (Math.random() < 0.3) {
    const x = rnd(0, window.innerWidth);
    const y = rnd(0, window.innerHeight);
    const c = rndColor();
    const el = document.createElement('div');
    el.style.cssText = `
      position:fixed;left:${x}px;top:${y}px;
      width:3px;height:3px;background:${c};
      pointer-events:none;z-index:100;
      box-shadow:0 0 4px ${c};
      animation:trailFade 1.5s ease forwards;
    `;
    el.className = 'trail-dot';
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 1500);
  }
}, 400);
</script>
 
