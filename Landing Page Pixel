      <rect x="2" y="17" width="5" height="2" fill="#ffe600"/>
      <rect x="8" y="17" width="5" height="2" fill="#ffe600"/>
    </svg>
  </div>
</section>
 
<!-- SKILLS -->
<section id="skills">
  <div class="container">
    <div class="section-header observe">
      <span class="section-label">// SKILL TREE</span>
      <h2 class="section-title">KEMAMPUAN <span>TEKNIS</span></h2>
      <div class="pixel-divider"></div>
