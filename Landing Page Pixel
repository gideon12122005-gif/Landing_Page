      <div class="skill-card">
        <span class="skill-icon">🟩</span>
        <div class="skill-name">NODE.JS</div>
        <div class="skill-bar"><div class="skill-fill" style="width:88%"></div></div>
        <div class="skill-lvl">LVL 88</div>
      </div>
      <div class="skill-card">
        <span class="skill-icon">🐍</span>
        <div class="skill-name">PYTHON / AI</div>
        <div class="skill-bar"><div class="skill-fill" style="width:80%"></div></div>
        <div class="skill-lvl">LVL 80</div>
      </div>
      <div class="skill-card">
        <span class="skill-icon">🗄️</span>
        <div class="skill-name">DATABASE</div>
        <div class="skill-bar"><div class="skill-fill" style="width:85%"></div></div>
        <div class="skill-lvl">LVL 85</div>
      </div>
      <div class="skill-card">
        <span class="skill-icon">📱</span>
        <div class="skill-name">REACT NATIVE</div>
        <div class="skill-bar"><div class="skill-fill" style="width:75%"></div></div>
        <div class="skill-lvl">LVL 75</div>
      </div>
      <div class="skill-card">
        <span class="skill-icon">☁️</span>
        <div class="skill-name">AWS / DEVOPS</div>
        <div class="skill-bar"><div class="skill-fill" style="width:70%"></div></div>
        <div class="skill-lvl">LVL 70</div>
      </div>
