      <rect x="3" y="6" width="9" height="6" fill="#00e5ff"/>
      <rect x="5" y="7" width="5" height="2" fill="#080808"/>
      <!-- Arms -->
      <rect x="0" y="6" width="3" height="4" fill="#00e5ff"/>
      <rect x="12" y="6" width="3" height="4" fill="#00e5ff"/>
      <!-- Legs -->
      <rect x="3" y="12" width="4" height="5" fill="#00ff88"/>
      <rect x="8" y="12" width="4" height="5" fill="#00ff88"/>
