const COLORS = ['#00ff88','#00e5ff','#ffe600','#ff3c5f','#ff00ff','#ff8800','#ffffff'];
const rndColor = () => COLORS[Math.floor(Math.random() * COLORS.length)];
const rnd = (a, b) => Math.random() * (b - a) + a;
const rndInt = (a, b) => Math.floor(rnd(a, b));
 
/* ---- CURSOR (desktop only) ---- */
const cursor = document.getElementById('cursor');
const isTouchDevice = window.matchMedia('(hover: none), (pointer: coarse)').matches;
let mx = 0, my = 0;
if (!isTouchDevice) {
  document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    cursor.style.left = mx - 8 + 'px';
    cursor.style.top  = my - 8 + 'px';
    if (Math.random() < 0.25) spawnTrail(mx, my);
  });
  document.addEventListener('mousedown', () => { cursor.style.transform = 'scale(0.6)'; cursor.style.background = rndColor(); });
  document.addEventListener('mouseup',   () => { cursor.style.transform = 'scale(1)'; });
}
 
/* ---- MOUSE TRAIL ---- */
function spawnTrail(x, y) {
  const d = document.createElement('div');
  d.className = 'trail-dot';
  const c = rndColor();
  d.style.cssText = `left:${x}px;top:${y}px;background:${c};box-shadow:0 0 4px ${c};`;
  document.body.appendChild(d);
  setTimeout(() => d.remove(), 500);
}
 
/* ---- COMBO SYSTEM ---- */
let combo = 0, comboTimer = null;
const comboEl = document.getElementById('combo-display');
const comboNum = document.getElementById('combo-num');
function addCombo() {
  combo++;
  comboNum.textContent = combo;
  comboEl.classList.add('show');
  comboNum.style.color = rndColor();
  clearTimeout(comboTimer);
  comboTimer = setTimeout(() => { combo = 0; comboEl.classList.remove('show'); }, 1800);
  if (combo > 0 && combo % 10 === 0) bigComboEffect();
}
function bigComboEffect() {
  const flash = document.getElementById('screen-flash');
  flash.style.background = rndColor();
  flash.style.opacity = '0.12';
  setTimeout(() => flash.style.opacity = '0', 120);
  showLabel(window.innerWidth/2, window.innerHeight/2, combo + 'x COMBO!!', 14, rndColor());
}
 
/* ---- CLICK LABEL ---- */
const WORDS = ['PIXEL!','BOOM!','WOW!','NICE!','FIRE!','GG!','EZ!','POW!','ZAP!','WIN!','OP!','YOSH!'];
function showLabel(x, y, text, size, color) {
  const el = document.createElement('div');
  el.className = 'click-label';
  el.textContent = text;
  el.style.cssText = `left:${x}px;top:${y}px;color:${color};font-size:${size||9}px;text-shadow:0 0 8px ${color};`;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 900);
}
 
/* ---- PIXEL EXPLOSION ---- */
function pixelExplosion(x, y) {
  const count = 14;
  for (let i = 0; i < count; i++) {
    const size = rndInt(4, 12);
    const c = rndColor();
    const angle = (i / count) * Math.PI * 2 + rnd(-0.3, 0.3);
    const dist = rnd(40, 110);
    const tx = Math.cos(angle) * dist;
    const ty = Math.sin(angle) * dist;
    const dur = rnd(0.5, 0.9);
    const el = document.createElement('div');
    el.className = 'px-particle';
    el.style.cssText = `
      left:${x}px; top:${y}px;
      width:${size}px; height:${size}px;
      background:${c}; box-shadow:0 0 6px ${c};
      --tx:${tx}px; --ty:${ty}px; --dur:${dur}s;
    `;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), dur * 1000 + 100);
  }
}
 
/* ---- RIPPLE WAVES ---- */
function rippleWave(x, y) {
  for (let i = 0; i < 3; i++) {
    setTimeout(() => {
      const c = rndColor();
      const el = document.createElement('div');
      el.className = 'ripple-wave';
      el.style.cssText = `left:${x}px;top:${y}px;--rc:${c};border-color:${c};`;
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 700);
    }, i * 120);
  }
}
 
/* ---- MINI SPRITES ---- */
const SPRITES = [
  // Human pixel
  (c) => `<svg width="14" height="20" viewBox="0 0 7 10" xmlns="http://www.w3.org/2000/svg">
