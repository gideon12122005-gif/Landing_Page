<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PIXEL.DEV — Portfolio</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap');
 
  :root {
    --black: #080808;
    --dark: #0d0d0d;
    --panel: #111111;
    --border: #1e1e1e;
    --green: #00ff88;
    --cyan: #00e5ff;
    --yellow: #ffe600;
    --red: #ff3c5f;
    --white: #f0f0f0;
    --gray: #444;
    --pixel: 4px;
  }
 
  * { margin: 0; padding: 0; box-sizing: border-box; }
 
  html { scroll-behavior: smooth; }
 
  body {
    background: var(--black);
    color: var(--white);
    font-family: 'VT323', monospace;
    font-size: 20px;
    overflow-x: hidden;
    cursor: none;
  }
 
  /* CUSTOM CURSOR */
  #cursor {
    width: 16px; height: 16px;
    background: var(--green);
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 9999;
    image-rendering: pixelated;
    clip-path: polygon(0 0, 60% 0, 100% 40%, 100% 100%, 40% 100%, 0 60%);
    transition: transform 0.1s;
    mix-blend-mode: screen;
  }
 
  /* PIXEL GRID BACKGROUND */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
  }
 
  /* SCANLINES */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.15) 2px,
      rgba(0,0,0,0.15) 4px
    );
    pointer-events: none;
    z-index: 0;
  }
 
  .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 1; }
 
  /* ===== NAVBAR ===== */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(8,8,8,0.9);
    border-bottom: 2px solid var(--green);
    backdrop-filter: blur(4px);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.75rem 2rem;
    max-width: 1100px; margin: 0 auto;
  }
  .nav-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: 14px;
    color: var(--green);
    text-shadow: 0 0 12px var(--green);
    letter-spacing: 1px;
  }
  .nav-logo span { color: var(--cyan); }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    color: var(--gray);
    text-decoration: none;
    font-size: 18px;
    transition: color 0.1s;
    letter-spacing: 1px;
  }
  .nav-links a:hover { color: var(--green); text-shadow: 0 0 8px var(--green); }
  .nav-status {
    display: flex; align-items: center; gap: 8px;
    font-size: 14px; color: var(--green);
  }
  .blink {
    display: inline-block; width: 10px; height: 10px;
    background: var(--green); border-radius: 0;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }
 
  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }
 
  .hero-bg-art {
    position: absolute;
    right: -40px; top: 50%;
    transform: translateY(-50%);
    width: 420px; height: 420px;
    opacity: 0.08;
    z-index: 0;
  }
 
  .hero-tag {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    color: var(--cyan);
    letter-spacing: 3px;
    margin-bottom: 1.5rem;
    animation: fadeUp 0.6s ease both;
  }
  .hero-tag::before { content: '> '; color: var(--green); }
 
  .hero-name {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(22px, 4vw, 42px);
    color: var(--white);
    line-height: 1.5;
    animation: fadeUp 0.6s 0.1s ease both;
    position: relative;
    z-index: 1;
  }
  .hero-name .highlight {
    color: var(--green);
    text-shadow: 0 0 20px var(--green), 0 0 40px rgba(0,255,136,0.3);
    display: block;
  }
 
  .hero-role {
    font-size: 28px;
    color: var(--yellow);
    margin-top: 1rem;
    animation: fadeUp 0.6s 0.2s ease both;
    position: relative; z-index: 1;
  }
  .hero-role::after {
    content: '_';
    animation: blink 0.8s steps(1) infinite;
  }
 
  .hero-desc {
    max-width: 500px;
    color: #888;
    line-height: 1.5;
    margin-top: 1.5rem;
    font-size: 19px;
    animation: fadeUp 0.6s 0.3s ease both;
    position: relative; z-index: 1;
  }
 
  .hero-btns {
    display: flex; gap: 1rem; flex-wrap: wrap;
    margin-top: 2.5rem;
    animation: fadeUp 0.6s 0.4s ease both;
    position: relative; z-index: 1;
  }
  .btn {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    padding: 14px 22px;
    cursor: pointer;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.1s;
    display: inline-block;
    position: relative;
  }
  .btn-primary {
    background: var(--green);
    color: var(--black);
    border: none;
    box-shadow: 4px 4px 0 #007744, 8px 8px 0 #003322;
  }
  .btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #007744, 10px 10px 0 #003322;
  }
  .btn-secondary {
    background: transparent;
    color: var(--cyan);
    border: 2px solid var(--cyan);
    box-shadow: 4px 4px 0 #005566;
  }
  .btn-secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #005566;
    background: rgba(0,229,255,0.05);
  }
 
  /* STATS ROW */
  .hero-stats {
    display: flex; gap: 2rem; flex-wrap: wrap;
    margin-top: 3rem;
    animation: fadeUp 0.6s 0.5s ease both;
    position: relative; z-index: 1;
  }
  .stat {
    display: flex; flex-direction: column; gap: 2px;
  }
  .stat-num {
    font-family: 'Press Start 2P', monospace;
    font-size: 20px;
    color: var(--yellow);
    text-shadow: 0 0 10px var(--yellow);
  }
  .stat-label { font-size: 15px; color: #555; letter-spacing: 1px; }
 
  /* PIXEL CHARACTER */
  .pixel-char {
    position: absolute; right: 10%; top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(-50%); }
    50% { transform: translateY(calc(-50% - 16px)); }
  }
 
  /* ===== SECTIONS ===== */
  section { padding: 5rem 0; position: relative; z-index: 1; }
 
  .section-header { margin-bottom: 3rem; }
  .section-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    color: var(--green);
    letter-spacing: 4px;
    display: block;
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(16px, 2.5vw, 24px);
    color: var(--white);
    line-height: 1.6;
  }
  .section-title span { color: var(--cyan); }
  .pixel-divider {
    height: 2px;
    background: repeating-linear-gradient(90deg, var(--green) 0px, var(--green) 8px, transparent 8px, transparent 16px);
    margin-top: 1rem;
    width: 120px;
  }
 
  /* ===== SKILLS ===== */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }
  .skill-card {
    background: var(--panel);
    border: 2px solid var(--border);
    padding: 1.25rem;
    position: relative;
    transition: all 0.1s;
    overflow: hidden;
  }
  .skill-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--green);
    transform: scaleX(0);
    transition: transform 0.2s;
    transform-origin: left;
  }
  .skill-card:hover { border-color: var(--green); transform: translate(-2px, -2px); box-shadow: 4px 4px 0 #003322; }
  .skill-card:hover::before { transform: scaleX(1); }
  .skill-icon { font-size: 28px; margin-bottom: 0.5rem; display: block; }
  .skill-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    color: var(--white);
    margin-bottom: 0.75rem;
    letter-spacing: 1px;
  }
  .skill-bar {
    height: 8px;
    background: #1a1a1a;
    border: 1px solid #222;
    position: relative;
    overflow: hidden;
  }
  .skill-fill {
    height: 100%;
    background: repeating-linear-gradient(90deg, var(--green) 0px, var(--green) 6px, #003322 6px, #003322 8px);
    transition: width 1s ease;
    box-shadow: 0 0 8px var(--green);
  }
  .skill-lvl {
    font-size: 13px;
    color: var(--green);
    margin-top: 4px;
  }
 
  /* ===== PROJECTS ===== */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .project-card {
    background: var(--panel);
    border: 2px solid var(--border);
    overflow: hidden;
    transition: all 0.15s;
    position: relative;
  }
  .project-card:hover {
    border-color: var(--cyan);
    transform: translate(-3px, -3px);
    box-shadow: 5px 5px 0 #003344, 8px 8px 0 #001122;
  }
  .project-preview {
    height: 160px;
    display: flex; align-items: center; justify-content: center;
    font-size: 64px;
    position: relative;
    overflow: hidden;
  }
  .proj-bg-1 { background: linear-gradient(135deg, #0a1a0a 0%, #0d2d0d 100%); }
  .proj-bg-2 { background: linear-gradient(135deg, #0a0a1a 0%, #0d0d2d 100%); }
  .proj-bg-3 { background: linear-gradient(135deg, #1a0a0a 0%, #2d0d0d 100%); }
  .proj-bg-4 { background: linear-gradient(135deg, #1a1a0a 0%, #2d2d0d 100%); }
  .project-preview::after {
    content: '';
    position: absolute; inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      rgba(0,0,0,0.2) 3px, rgba(0,0,0,0.2) 4px
    );
  }
  .project-body { padding: 1.25rem; }
  .project-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .tag {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    padding: 4px 8px;
    background: #0a1a0a;
    border: 1px solid var(--green);
    color: var(--green);
    letter-spacing: 1px;
  }
  .tag.cyan { background: #0a1a1a; border-color: var(--cyan); color: var(--cyan); }
  .tag.yellow { background: #1a1a0a; border-color: var(--yellow); color: var(--yellow); }
  .tag.red { background: #1a0a0a; border-color: var(--red); color: var(--red); }
  .project-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 11px;
    color: var(--white);
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .project-desc { font-size: 17px; color: #666; line-height: 1.4; }
  .project-footer {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border);
  }
  .project-link {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    color: var(--cyan);
    text-decoration: none;
    letter-spacing: 1px;
  }
  .project-link:hover { text-shadow: 0 0 8px var(--cyan); }
 
  /* ===== EXPERIENCE ===== */
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px;
    background: repeating-linear-gradient(180deg, var(--green) 0px, var(--green) 8px, transparent 8px, transparent 16px);
  }
  .timeline-item {
    position: relative;
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--panel);
    border: 2px solid var(--border);
    transition: border-color 0.2s;
  }
  .timeline-item::before {
    content: '▶';
    position: absolute; left: -2.5rem; top: 1.25rem;
    color: var(--green);
    font-size: 14px;
  }
  .timeline-item:hover { border-color: var(--green); }
  .timeline-date {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    color: var(--yellow);
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }
  .timeline-role {
    font-family: 'Press Start 2P', monospace;
    font-size: 11px;
    color: var(--white);
    margin-bottom: 0.25rem;
    line-height: 1.6;
  }
  .timeline-company { font-size: 18px; color: var(--cyan); margin-bottom: 0.5rem; }
  .timeline-desc { font-size: 17px; color: #666; line-height: 1.5; }
 
  /* ===== CONTACT ===== */
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 3rem;
  }
  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--panel);
    border: 2px solid var(--border);
    transition: all 0.1s;
    text-decoration: none;
  }
  .contact-item:hover { border-color: var(--green); transform: translateX(4px); }
  .contact-icon {
    font-size: 24px;
    width: 40px; text-align: center;
  }
  .contact-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    color: #555; margin-bottom: 4px; letter-spacing: 1px;
  }
  .contact-value { font-size: 18px; color: var(--white); }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 8px; color: var(--green); letter-spacing: 2px;
  }
  .form-input {
    background: var(--panel);
    border: 2px solid var(--border);
    color: var(--white);
    font-family: 'VT323', monospace;
    font-size: 18px;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.1s;
  }
  .form-input:focus { border-color: var(--green); box-shadow: 0 0 8px rgba(0,255,136,0.2); }
  textarea.form-input { resize: none; height: 100px; }
 
  /* ===== FOOTER ===== */
  footer {
    border-top: 2px solid var(--border);
    padding: 2rem 0;
    text-align: center;
    position: relative; z-index: 1;
  }
  .footer-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: 12px;
    color: var(--green);
    text-shadow: 0 0 12px var(--green);
    margin-bottom: 1rem;
  }
  .footer-text { font-size: 16px; color: #444; }
  .footer-text span { color: var(--red); }
 
  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
 
  /* GLITCH on hover for hero name */
  .hero-name:hover .highlight {
    animation: glitch 0.3s steps(1) infinite;
  }
  @keyframes glitch {
    0% { text-shadow: 0 0 20px var(--green), 0 0 40px rgba(0,255,136,0.3); clip-path: none; }
    25% { text-shadow: -2px 0 var(--red), 2px 0 var(--cyan); }
    50% { text-shadow: 2px 0 var(--cyan), -2px 0 var(--red); clip-path: inset(20% 0 40% 0); }
    75% { text-shadow: 0 0 20px var(--green); }
    100% { text-shadow: 0 0 20px var(--green), 0 0 40px rgba(0,255,136,0.3); clip-path: none; }
  }
 
  /* corner decorations */
  .corner-tl, .corner-br {
    position: absolute;
    width: 20px; height: 20px;
  }
  .corner-tl {
    top: 0; left: 0;
    border-top: 2px solid var(--green);
    border-left: 2px solid var(--green);
  }
  .corner-br {
    bottom: 0; right: 0;
    border-bottom: 2px solid var(--green);
    border-right: 2px solid var(--green);
  }
 
  /* SCROLL OBSERVER */
  .observe { opacity: 0; transform: translateY(24px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .observe.visible { opacity: 1; transform: none; }
 
  @media (max-width: 700px) {
    .pixel-char { display: none; }
    .contact-grid { grid-template-columns: 1fr; }
    .nav-links { display: none; }
  }
</style>
</head>
<body>
 
<div id="cursor"></div>
 
<!-- NAV -->
<nav>
  <div class="nav-inner">
    <div class="nav-logo">PX<span>.</span>DEV</div>
    <ul class="nav-links">
      <li><a href="#skills">SKILLS</a></li>
      <li><a href="#projects">PROJECTS</a></li>
      <li><a href="#experience">EXP</a></li>
      <li><a href="#contact">CONTACT</a></li>
    </ul>
    <div class="nav-status"><span class="blink"></span> AVAILABLE FOR HIRE</div>
  </div>
</nav>
 
<!-- HERO -->
<section class="hero">
  <div class="container">
    <p class="hero-tag">PLAYER ONE HAS ENTERED</p>
    <h1 class="hero-name">
      HALO, SAYA<br>
      <span class="highlight">BUDI SANTOSO</span>
    </h1>
    <p class="hero-role">FULLSTACK DEVELOPER</p>
    <p class="hero-desc">
      Crafting digital experiences satu pixel dalam satu waktu. Spesialis web app, mobile, dan AI integration — dari Jakarta untuk dunia.
    </p>
    <div class="hero-btns">
      <a href="#projects" class="btn btn-primary">▶ LIHAT PROYEK</a>
      <a href="#contact" class="btn btn-secondary">✉ HIRE ME</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">5+</span>
        <span class="stat-label">YEARS EXP</span>
      </div>
      <div class="stat">
        <span class="stat-num">40+</span>
        <span class="stat-label">PROJECTS</span>
      </div>
      <div class="stat">
        <span class="stat-num">20+</span>
        <span class="stat-label">CLIENTS</span>
      </div>
      <div class="stat">
        <span class="stat-num">∞</span>
        <span class="stat-label">COFFEE CUPS</span>
      </div>
    </div>
  </div>
 
  <!-- Pixel Character SVG -->
  <div class="pixel-char">
    <svg width="120" height="160" viewBox="0 0 15 20" xmlns="http://www.w3.org/2000/svg" style="image-rendering:pixelated;">
